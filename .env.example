# ══════════════════════════════════════════════════════════════════════════════
# BACKEND — copy to backend/.env
# ══════════════════════════════════════════════════════════════════════════════
PORT=5000
MONGODB_URI=mongodb://localhost:27017/ai_support
NODE_ENV=development

# ── Auth ──────────────────────────────────────────────────────────────────────
# Both are REQUIRED and must be >= 32 chars. The server refuses to boot otherwise,
# and in production it also rejects these placeholder values.
# Generate each with:  openssl rand -base64 48
JWT_SECRET=change_me_generate_a_real_48_byte_random_secret
JWT_REFRESH_SECRET=change_me_generate_a_DIFFERENT_48_byte_secret

# Allowed dashboard origins for the credentialed CORS policy.
# Comma-separate multiple: https://app.vercel.app,https://preview.vercel.app
# Comma-separated: every origin allowed to make credentialed calls to the dashboard API.
FRONTEND_URL=http://localhost:3000,http://localhost:3001

# Signs the public widget's chat session tokens. Falls back to JWT_SECRET if unset.
# WIDGET_SECRET=

# Public origin of THIS API. Only needed when Twilio webhooks arrive through a
# proxy, so the signature is validated against the URL Twilio actually signed.
# PUBLIC_API_URL=https://api.yourdomain.com

# ── AI: answer generation ─────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...          # https://console.groq.com  (free)

# ── AI: embeddings ────────────────────────────────────────────────────────────
# Cohere embed-english-v3.0 (1024-dim, free tier) is the ONLY embedding provider
# supported — src/services/embedding.service.ts calls Cohere's API directly.
# There is no EMBEDDING_PROVIDER switch.
#
# Without this key, uploads are stored but every document ends up status
# "failed" with 0 chunks and bots answer with no knowledge base.
COHERE_API_KEY=...            # https://dashboard.cohere.com/api-keys

# ── AI: fallback (optional) ───────────────────────────────────────────────────
# Used only when Groq fails. OpenRouter (OpenAI-compatible) by default.
# If unset, a Groq outage means an apology reply plus an auto-created ticket.
# FALLBACK_AI_API_KEY=
# FALLBACK_AI_BASE_URL=https://openrouter.ai/api/v1
# FALLBACK_AI_MODEL=openai/gpt-4o-mini

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Payments: Razorpay (subscriptions) ────────────────────────────────────────
# REQUIRED in production — the server refuses to boot without KEY_ID, KEY_SECRET,
# and WEBHOOK_SECRET. Use test keys until KYC + go-live. Plan ids come from the
# Plans you create in the Razorpay dashboard (monthly, INR); a tier with no id
# simply isn't offered for checkout.
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...        # subscribe the webhook to subscription.* events
# RAZORPAY_PLAN_STARTER=plan_...
# RAZORPAY_PLAN_PRO=plan_...
# Days a lapsed subscription keeps serving before it is disabled (dunning window).
# GRACE_PERIOD_DAYS=7

# ── Object storage for KB uploads ─────────────────────────────────────────────
# "local" (default) keeps files on disk — fine for dev, but the disk is ephemeral
# on Vercel/Railway so uploads vanish on redeploy. Set "s3" for durable storage on
# any S3-compatible bucket: AWS S3 (omit S3_ENDPOINT) or Cloudflare R2 (set it).
# STORAGE_DRIVER=local
# S3_BUCKET=astrex-kb
# S3_REGION=auto                     # "auto" for R2; a real region for AWS
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com   # R2/custom only
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_PUBLIC_BASE_URL=                # optional CDN/public base for object URLs

# ── Data retention (DPDP) ─────────────────────────────────────────────────────
# Days after a conversation is soft-deleted (deletedAt) before it is hard-purged.
# 0 (default) disables the purge job entirely.
# DATA_RETENTION_DAYS=0

# ── Error tracking: Sentry (optional) ─────────────────────────────────────────
# Backend. Unset = SDK never initialises and capture calls are no-ops.
# SENTRY_DSN=https://...ingest.sentry.io/...
# SENTRY_TRACES_SAMPLE_RATE=0        # 0..1; raise for performance tracing
#
# Uptime: point an external monitor (UptimeRobot / BetterStack) at GET /ready
# (checks Mongo + Qdrant); use GET /health for a cheap liveness ping.

# ── Email (password reset) ────────────────────────────────────────────────────
# If not set, reset links are printed to the backend console (dev only)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=SG...               # SendGrid API key
# SMTP_FROM=no-reply@yourdomain.com

# ── Integrations ──────────────────────────────────────────────────────────────
# Shared secret for the inbound email-to-ticket webhook, sent as x-webhook-secret.
# REQUIRED in production — without it POST /api/integrations/email returns 503.
# EMAIL_WEBHOOK_SECRET=

# WhatsApp via Twilio. TWILIO_AUTH_TOKEN is also what validates the webhook
# signature; in production the webhook returns 503 without it.
# NOTE: WHATSAPP_TENANT_ID pins every inbound WhatsApp message to one tenant —
# this integration is single-tenant as written.
# WHATSAPP_TENANT_ID=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=

# ══════════════════════════════════════════════════════════════════════════════
# FRONTEND — copy to frontend/.env.local
# ══════════════════════════════════════════════════════════════════════════════

# Where Next.js proxies /api/* to. Server-side only — never sent to the browser.
# This proxy is what keeps the auth cookie same-origin so middleware can read it.
# BACKEND_URL=http://localhost:5000

# MUST match the backend's values exactly. The middleware verifies the session
# cookie's signature with these. Server-side only (no NEXT_PUBLIC_ prefix).
# JWT_SECRET=
# JWT_REFRESH_SECRET=

# Socket.IO connects to the backend directly (not proxied), so this is public.
# NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# Public origin of the API — used only to build widget embed snippets shown in
# the dashboard. Dashboard API calls go through the proxy, not this.
# NEXT_PUBLIC_API_URL=http://localhost:5000

# Client-side error tracking (Sentry). Unset = disabled. Use a SEPARATE Sentry
# project/DSN from the backend.
# NEXT_PUBLIC_SENTRY_DSN=https://...ingest.sentry.io/...
# NEXT_PUBLIC_SENTRY_ENV=production
