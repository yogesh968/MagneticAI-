# Backend
PORT=5000
MONGODB_URI=mongodb://localhost:27017/ai_support
JWT_SECRET=change_me_256bit_random_secret
JWT_REFRESH_SECRET=change_me_refresh_secret_256bit
# For production set to your Vercel URL (comma-separate multiple: https://app.vercel.app,https://preview.vercel.app)
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ── LLM (pick one) ─────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...          # https://console.groq.com  (free)

# ── Embeddings — set EMBEDDING_PROVIDER to one of: huggingface | openai | cohere | ollama
EMBEDDING_PROVIDER=huggingface

# Hugging Face (free, no key required — add key to avoid rate limits)
# HF_API_KEY=hf_...           # https://huggingface.co/settings/tokens
# HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2   # 384-dim (default)
# HF_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5                   # 1024-dim (better quality)
# HF_VECTOR_SIZE=384          # must match the model above

# OpenAI embeddings (text-embedding-3-small, 1536-dim)
# OPENAI_API_KEY=sk-...

# Cohere embeddings (embed-english-v3.0, 1024-dim, free tier)
# COHERE_API_KEY=...

# Ollama local embeddings (nomic-embed-text, 768-dim, no key)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Email (password reset) ────────────────────────────────────────────────────
# If not set, reset links are printed to the backend console (dev only)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=SG...               # SendGrid API key
# SMTP_FROM=no-reply@yourdomain.com

# Frontend — copy to frontend/.env.local ───────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:5000
# NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
