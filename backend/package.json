{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "tsx src/seed.ts",
    "lint": "eslint src --ext .ts",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --forceExit",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest tests/unit --forceExit",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest tests/integration --forceExit",
    "test:ai": "NODE_OPTIONS=--experimental-vm-modules jest tests/integration/chat.test --forceExit"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "setupFilesAfterFramework": [
      "./tests/setup.ts"
    ],
    "testTimeout": 30000
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.13.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.5.0",
    "groq-sdk": "^0.9.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.9.0",
    "mongoose": "^8.12.1",
    "multer": "^1.4.5-lts.2",
    "nodemailer": "^8.0.11",
    "pdf-parse": "^1.1.1",
    "socket.io": "^4.8.1",
    "twilio": "^6.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^8.0.1",
    "@types/pdf-parse": "^1.1.4",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.22.0",
    "jest": "^29.7.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0"
  }
}
